# dependencies
node_modules/

repos/

# vendored reference clones — re-cloneable, deliberately unpinned (see references/README.md)
references/*
!references/README.md

*.local*

# duet run state (per-repo working data, never committed) — except the tracked
# framing templates + the carve itself, shared across worktrees (docs/automation-design.md).
.duet/*
!.duet/.gitignore
!.duet/templates/
!.duet/templates/**

# publish-only bundle output (`pnpm build`); dev runs src/ directly
dist/

# logs & OS noise
*.log
.DS_Store

# claude code harness noise
.claude/*.lock
