{
  "name": "duet",
  "version": "0.1.0",
  "private": true,
  "description": "Semi-AFK orchestrator for the two-agent cross-review workflow: a read-only LLM orchestrator routes a snippet protocol between an implementer and a reviewer, inside a code-enforced phase-and-gate skeleton.",
  "license": "MIT",
  "author": "qiushiyan <qiushi.yann@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiushiyan/duet.git"
  },
  "type": "module",
  "bin": {
    "duet": "src/cli.ts"
  },
  "publishConfig": {
    "bin": {
      "duet": "dist/cli.mjs"
    }
  },
  "files": [
    "dist",
    "snippets.toml"
  ],
  "scripts": {
    "duet": "node src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsdown",
    "prepack": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "^0.133.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.6.1",
    "xstate": "^5.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "publint": "^0.3.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2"
}
